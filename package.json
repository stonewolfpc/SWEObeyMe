    "test:clean-env": "node .github/scripts/test-clean-env-simulation.js",
    "test:strict-dupes": "node .github/scripts/test-strict-duplicates.js",
    "test:ui": "node .github/scripts/test-ui-components.js",
    "test:os": "node .github/scripts/test-os-compatibility.js",
    "test:artifacts": "node .github/scripts/test-build-artifacts.js",
    "test:cross-platform": "node tests/cross-platform-integration-test.js",
    "test:schema-validation": "node tests/backend-mcp-schema-validation.js",
    "test:concurrency": "node tests/backend-mcp-concurrency.js",
    "test:file-safety": "node tests/backend-mcp-file-system-safety.js",
