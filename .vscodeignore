# ============================================
# VSCode Extension Packaging Configuration
# ============================================
# This extension is bundled using esbuild. Only include
# the bundled dist/ directory and essential metadata files.
# All source files are already bundled into dist/.

# ============================================
# Include Essential Files
# ============================================
!dist/**
!dist/lib/**
!package.json
!README.md
!LICENSE
!icon.png
!.sweignore

# ============================================
# Exclude Source Files (already bundled)
# ============================================
lib/
utils/
docs/
examples/
scripts/
test-tools/
index.js
extension.js
quotes.js
esbuild.config.js

# ============================================
# Exclude Test Files
# ============================================
tests/
__tests__/
*.test.js
*.spec.js
**/test/**
vscode/
test-electron/

# ============================================
# Exclude QA Suite (local-only, NEVER in release)
# ============================================
qa/
vitest.config.qa.js

# ============================================
# Exclude Git and Development Files
# ============================================
.git/
.gitignore
.github/
.vscode/
.idea/
ares-rig/
windsurf-rig/

# ============================================
# Exclude Dependencies
# ============================================
node_modules/

# ============================================
# Exclude Documentation (except README)
# =================================<arg_value>
ANTI_PATTERNS.md
BEST_PRACTICES.md
CODE_OF_CONDUCT.md
COMMON_PATTERNS.md
CONFIGURATION_EXAMPLES.md
CONTRIBUTING.md
DECISION_TREE.md
FAQ.md
PERFORMANCE_TIPS.md
QUICKSTART.md
SECURITY.md
TROUBLESHOOTING.md
CHANGELOG.md
docs/
*.md
!README.md

# ============================================
# Exclude Build Artifacts
# ============================================
build/
*.vsix
*.tgz

# ============================================
# Exclude Temp and Dump Files
# ============================================
dump*.txt
*.tmp
*.log
*.bak
*.swp

# ============================================
# Exclude Error Logs (test artifacts)
# ============================================
error_log.json
error_patterns.json

# ============================================
# Exclude Backup Directories
# ============================================
project_registry/
backup/
backups/

# ============================================
# Exclude Tool Memory and Corpus Files
# ============================================
scripts/tool-memory.json
math_corpus/
fdq_corpus/
training_corpus/
csharp_dotnet_corpus/
cpp_corpus/
git_corpus/
enterprise_security_corpus/
ide_mcp_corpus/
mcp_implementation_corpus/
nodejs_runtime_corpus/
performance_profiling_corpus/
security_csp_corpus/
testing_qa_corpus/
typescript_javascript_corpus/
vscode_extension_corpus/
web_development_corpus/
build_deployment_corpus/

# ============================================
# Exclude Configuration Files
# ============================================
.eslintrc.js
.prettierrc
.lintstagedrc.js
.czrc
.releaserc.json
.husky/

# ============================================
# Exclude Workflows
# ============================================
.windsurf/

# ============================================
# Exclude Schemas and Project Files
# ============================================
project_map.schema.json
.sweobeyme-memory.json
project_map.json
tool-memory.json
.windsurfrules

# ============================================
# Exclude Additional Directories and Files
# ============================================
.code-dumps/
.local/
git-governor/
godot_corpus/
plugins/
schemas/
temp/
Dockerfile
index.mjs
jest.config.js
package-lock.json
