{
  "name": "swe-obey-me",
  "displayName": "SWEObeyMe",
  "description": "SWEObeyMe - Surgical governance system for VS Code with MCP server integration",
  "version": "1.2.1",
  "type": "module",
  "publisher": "stonewolfpc",
  "icon": "icon.png",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "mcp",
    "ai",
    "code quality",
    "architecture",
    "surgical",
    "windsurf",
    "cascade"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sweObeyMe.queryOracle",
        "title": "Query the Oracle",
        "category": "SWEObeyMe"
      },
      {
        "command": "sweObeyMe.openCSharpSettings",
        "title": "C# Bridge Settings",
        "category": "SWEObeyMe",
        "icon": "$(settings-gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sweObeyMe",
          "title": "SWEObeyMe",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "sweObeyMe": [
        {
          "type": "webview",
          "id": "sweObeyMe.csharpSettings",
          "name": "C# Bridge",
          "when": "config.sweObeyMe.enabled"
        }
      ]
    },
    "configuration": {
      "title": "SWEObeyMe",
      "properties": {
        "sweObeyMe.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable SWEObeyMe MCP Server"
        },
        "sweObeyMe.csharpBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable C# Bridge error detection"
        },
        "sweObeyMe.csharpBridge.keepAiInformed": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inform AI about C# errors in file reads"
        },
        "sweObeyMe.csharpBridge.severityThreshold": {
          "type": "number",
          "default": 0,
          "description": "Minimum severity level to report (0=Info, 1=Warning, 2=Error)"
        },
        "sweObeyMe.csharpBridge.confidenceThreshold": {
          "type": "number",
          "default": 70,
          "description": "Minimum confidence percentage to show alerts (0-100)"
        },
        "sweObeyMe.csharpBridge.deduplicateAlerts": {
          "type": "boolean",
          "default": true,
          "description": "Group identical warnings to reduce noise"
        },
        "sweObeyMe.csharpBridge.alertCooldown": {
          "type": "number",
          "default": 30,
          "description": "Cooldown in seconds before repeating same alert"
        },
        "sweObeyMe.csharpBridge.logVerbosity": {
          "type": "string",
          "default": "errors",
          "enum": ["silent", "errors", "verbose"],
          "description": "Log verbosity level"
        },
        "sweObeyMe.csharpBridge.detectors": {
          "type": "object",
          "default": {
            "missingUsing": true,
            "emptyCatch": true,
            "deepNesting": true,
            "asyncAwait": true,
            "resourceLeaks": true,
            "mathSafety": true,
            "nullReference": true,
            "staticMutation": true,
            "stringConcatenation": true
          },
          "description": "Enable/disable specific error detectors"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish",
    "start": "node index.js",
    "build": "echo 'No build step required for this project'",
    "test": "npm run test:integration && npm run test:protocol && npm run test:schemas && npm run test:csharp",
    "test:integration": "node tests/mcp-integration.js",
    "test:protocol": "node tests/mcp-protocol-compliance.js",
    "test:schemas": "node test-tools/test-all-schemas.js",
    "test:csharp": "node test-tools/test-csharp-tools.js",
    "lint": "echo 'Linting not configured'",
    "format": "echo 'Formatting not configured'",
    "commit": "echo 'Commit tool not configured'"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.15.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "fs-extra": "^11.3.4",
    "jimp": "^1.6.0",
    "zod": "latest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stonewolfpc/SWEObeyMe"
  },
  "license": "SEE LICENSE IN LICENSE FILE"
}
