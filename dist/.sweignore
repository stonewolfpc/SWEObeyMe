# SWEObeyMe Ignore Patterns
# Files/directories to exclude from AI context

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
out/
*.exe
*.dll

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Test coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Git
.git/
.gitignore

# Large binary files
*.zip
*.tar.gz
*.rar
*.7z
*.iso
*.img

# Documentation (if too large)
# docs/
# *.md

# Secrets (never let AI see these)
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
secrets/

# Cache
.cache/
*.cache
