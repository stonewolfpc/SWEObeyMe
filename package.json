    "prepackage": "npm run build && npm run test:ui-regression && npm run test:git && npm run test:protocol && npm run test:comprehensive && npm run test:all && npm run test:csharp && node tests/uri-validation.js && npm run fuzz:all",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
