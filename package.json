{
  "name": "swe-obey-me",
  "displayName": "SWEObeyMe",
  "description": "SWEObeyMe - Surgical governance system for VS Code with MCP server integration. v2.0.10-beta: Fixed MCP config auto-propagation to correct windsurf-next path (~/.codeium/windsurf-next/mcp_config.json).",
  "version": "2.0.10-beta",
  "type": "module",
  "publisher": "stonewolfpc",
  "icon": "icon.png",
  "main": "dist/extension.js",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "mcp",
    "ai",
    "code quality",
    "architecture",
    "surgical",
    "windsurf",
    "cascade"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "mcpServers": [
      {
        "id": "sweobeyme",
        "command": "node",
        "args": [
          "./dist/mcp/server.js"
        ],
        "name": "SWEObeyMe",
        "description": "Surgical governance system for AI-assisted software engineering"
      }
    ],
    "commands": [
      {
        "command": "sweObeyMe.queryOracle",
        "title": "Query the Oracle",
        "category": "SWEObeyMe"
      },
      {
        "command": "sweObeyMe.showMenu",
        "title": "Show SWEObeyMe Menu",
        "category": "SWEObeyMe",
        "icon": "$(menu)"
      },
      {
        "command": "sweObeyMe.csharpSettings",
        "title": "Open C# Bridge Settings",
        "category": "SWEObeyMe",
        "icon": "$(settings-gear)"
      },
      {
        "command": "sweObeyMe.analyzeCSharp",
        "title": "Analyze Current C# File",
        "category": "SWEObeyMe",
        "icon": "$(search)"
      },
      {
        "command": "sweObeyMe.showDiagnostics",
        "title": "Show Diagnostics Panel",
        "category": "SWEObeyMe",
        "icon": "$(warning)"
      },
      {
        "command": "sweObeyMe.openCSharpSettings",
        "title": "SWEObeyMe Settings",
        "category": "SWEObeyMe",
        "icon": "$(settings-gear)"
      },
      {
        "command": "sweObeyMe.gitStatus",
        "title": "Show Git Status",
        "category": "SWEObeyMe",
        "icon": "$(git-branch)"
      },
      {
        "command": "sweObeyMe.gitBranch",
        "title": "Switch Git Branch",
        "category": "SWEObeyMe",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "sweObeyMe.checkpoint.create",
        "title": "Create Checkpoint",
        "category": "SWEObeyMe",
        "icon": "$(save)"
      },
      {
        "command": "sweObeyMe.checkpoint.list",
        "title": "List Checkpoints",
        "category": "SWEObeyMe",
        "icon": "$(list-tree)"
      },
      {
        "command": "sweObeyMe.checkpoint.revert",
        "title": "Revert to Checkpoint",
        "category": "SWEObeyMe",
        "icon": "$(discard)"
      },
      {
        "command": "sweObeyMe.checkpoint.delete",
        "title": "Delete Checkpoint",
        "category": "SWEObeyMe",
        "icon": "$(trash)"
      },
      {
        "command": "sweObeyMe.showOnboarding",
        "title": "Show Onboarding Guide",
        "category": "SWEObeyMe",
        "icon": "$(book)"
      },
      {
        "command": "sweObeyMe.patreonAudit",
        "title": "Patreon Audit",
        "category": "SWEObeyMe",
        "icon": "$(search)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sweObeyMe",
          "title": "SWEObeyMe",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "sweObeyMe": [
        {
          "type": "webview",
          "id": "sweObeyMe.csharpSettings",
          "name": "Settings",
          "when": "config.sweObeyMe.enabled",
          "icon": "$(settings-gear)"
        },
        {
          "type": "webview",
          "id": "sweObeyMe.csharpSettingsView",
          "name": "C# Bridge Settings",
          "icon": "$(settings-gear)"
        },
        {
          "type": "webview",
          "id": "sweObeyMe.adminDashboard",
          "name": "SWEObeyMe Admin Dashboard",
          "icon": "$(shield)"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sweObeyMe.queryOracle",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "config.sweObeyMe.enabled"
      },
      {
        "command": "sweObeyMe.showMenu",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "config.sweObeyMe.enabled"
      },
      {
        "command": "sweObeyMe.csharpSettings",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s",
        "when": "config.sweObeyMe.enabled"
      },
      {
        "command": "sweObeyMe.analyzeCSharp",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "config.sweObeyMe.enabled && editorLangId == 'csharp'"
      },
      {
        "command": "sweObeyMe.showDiagnostics",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "config.sweObeyMe.enabled"
      },
      {
        "command": "sweObeyMe.gitStatus",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "config.sweObeyMe.enabled"
      },
      {
        "command": "sweObeyMe.gitBranch",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "config.sweObeyMe.enabled"
      }
    ],
    "configuration": {
      "title": "SWEObeyMe",
      "properties": {
        "sweObeyMe.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable SWEObeyMe MCP Server"
        },
        "sweObeyMe.backupPath": {
          "type": "string",
          "default": "",
          "description": "Custom backup directory path (leave empty for default)"
        },
        "sweObeyMe.csharpBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable C# Bridge error detection"
        },
        "sweObeyMe.csharpBridge.keepAiInformed": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inform AI about C# errors in file reads"
        },
        "sweObeyMe.csharpBridge.severityThreshold": {
          "type": "number",
          "default": 0,
          "description": "Minimum severity level to report (0=Info, 1=Warning, 2=Error)"
        },
        "sweObeyMe.csharpBridge.confidenceThreshold": {
          "type": "number",
          "default": 70,
          "description": "Minimum confidence percentage to show alerts (0-100)"
        },
        "sweObeyMe.csharpBridge.deduplicateAlerts": {
          "type": "boolean",
          "default": true,
          "description": "Group identical warnings to reduce noise"
        },
        "sweObeyMe.csharpBridge.alertCooldown": {
          "type": "number",
          "default": 30,
          "description": "Cooldown in seconds before repeating same alert"
        },
        "sweObeyMe.csharpBridge.logVerbosity": {
          "type": "string",
          "default": "errors",
          "enum": [
            "silent",
            "errors",
            "verbose"
          ],
          "description": "Log verbosity level"
        },
        "sweObeyMe.csharpBridge.detectors": {
          "type": "object",
          "default": {
            "missingUsing": true,
            "emptyCatch": true,
            "deepNesting": true,
            "asyncAwait": true,
            "resourceLeaks": true,
            "mathSafety": true,
            "nullReference": true,
            "staticMutation": true,
            "stringConcatenation": true
          },
          "description": "Enable/disable specific error detectors"
        },
        "sweObeyMe.initialization.scanOnNewProject": {
          "type": "boolean",
          "default": true,
          "description": "Always scan on new project"
        },
        "sweObeyMe.initialization.scanOnLoad": {
          "type": "boolean",
          "default": false,
          "description": "Always scan on load"
        },
        "sweObeyMe.initialization.scanOnlyWhenAsked": {
          "type": "boolean",
          "default": false,
          "description": "Scan only when asked"
        },
        "sweObeyMe.initialization.scanOnlyOnProjectMapChange": {
          "type": "boolean",
          "default": false,
          "description": "Scan only when project map changes"
        },
        "sweObeyMe.initialization.neverScan": {
          "type": "boolean",
          "default": false,
          "description": "Never scan"
        },
        "sweObeyMe.initialization.reportDetailLevel": {
          "type": "string",
          "default": "standard",
          "enum": [
            "minimal",
            "standard",
            "full",
            "debug"
          ],
          "description": "Report detail level"
        },
        "sweObeyMe.initialization.digitalDebtThreshold": {
          "type": "string",
          "default": "20",
          "enum": [
            "10",
            "20",
            "50",
            "always"
          ],
          "description": "Digital debt threshold for warnings"
        },
        "sweObeyMe.initialization.autoFixNaming": {
          "type": "boolean",
          "default": false,
          "description": "Auto-fix naming inconsistencies"
        },
        "sweObeyMe.initialization.autoFixFolderStructure": {
          "type": "boolean",
          "default": false,
          "description": "Auto-fix folder structure"
        },
        "sweObeyMe.initialization.autoFixDocumentation": {
          "type": "boolean",
          "default": false,
          "description": "Auto-fix documentation"
        },
        "sweObeyMe.initialization.autoFixTests": {
          "type": "boolean",
          "default": false,
          "description": "Auto-fix tests"
        },
        "sweObeyMe.initialization.autoFixDigitalDebt": {
          "type": "boolean",
          "default": false,
          "description": "Auto-fix digital debt"
        },
        "sweObeyMe.initialization.neverAutoFix": {
          "type": "boolean",
          "default": true,
          "description": "Never auto-fix"
        },
        "sweObeyMe.initialization.toolPriority": {
          "type": "string",
          "default": "mcp",
          "enum": [
            "mcp",
            "windsurf",
            "none"
          ],
          "description": "Tool priority: MCP tools first, Windsurf tools second, or no built-in tools"
        },
        "sweObeyMe.initialization.transparencyMode": {
          "type": "string",
          "default": "major",
          "enum": [
            "everything",
            "major",
            "silent"
          ],
          "description": "Transparency mode: explain everything, only major decisions, or silent"
        },
        "sweObeyMe.general.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show SWEObeyMe status bar indicator"
        },
        "sweObeyMe.general.codeLensEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens for quick actions on C# files"
        },
        "sweObeyMe.general.hotReloadEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable hot-reload for extension changes"
        },
        "sweObeyMe.mathCorpus.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable math corpus for mathematical reference"
        },
        "sweObeyMe.mathCorpus.autoLookup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically lookup math concepts when detected"
        },
        "sweObeyMe.godotIntegration.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Godot project detection and enforcement"
        },
        "sweObeyMe.godotIntegration.strictMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable strict Godot project structure enforcement"
        },
        "sweObeyMe.godotIntegration.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect Godot projects on workspace open"
        },
        "sweObeyMe.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show SWEObeyMe notifications"
        },
        "sweObeyMe.notifications.soundEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Play notification sounds"
        },
        "sweObeyMe.advanced.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for troubleshooting"
        },
        "sweObeyMe.advanced.experimentalFeatures": {
          "type": "boolean",
          "default": false,
          "description": "Enable experimental features (may be unstable)"
        },
        "sweObeyMe.providers.ollama.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable local Ollama provider support"
        },
        "sweObeyMe.providers.ollama.endpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API endpoint URL"
        },
        "sweObeyMe.providers.ollama.models": {
          "type": "array",
          "default": [],
          "description": "Available Ollama models (e.g., [\"llama2\", \"codellama\"])"
        },
        "sweObeyMe.providers.openai.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable OpenAI provider support"
        },
        "sweObeyMe.providers.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key (leave empty to use environment variable)"
        },
        "sweObeyMe.providers.anthropic.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Anthropic provider support"
        },
        "sweObeyMe.providers.anthropic.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key (leave empty to use environment variable)"
        },
        "sweObeyMe.checkpoints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable named checkpoints and revert functionality"
        },
        "sweObeyMe.checkpoints.maxCount": {
          "type": "number",
          "default": 10,
          "description": "Maximum number of checkpoints to retain"
        },
        "sweObeyMe.checkpoints.autoCreate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically create checkpoint before major operations"
        },
        "sweObeyMe.diffReview.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable diff review before approval"
        },
        "sweObeyMe.diffReview.showSideBySide": {
          "type": "boolean",
          "default": true,
          "description": "Show diff in side-by-side view"
        },
        "sweObeyMe.diffReview.requireApproval": {
          "type": "boolean",
          "default": true,
          "description": "Require user approval before applying changes"
        },
        "sweObeyMe.toolControls.perAgent": {
          "type": "boolean",
          "default": true,
          "description": "Enable per-agent tool control permissions"
        },
        "sweObeyMe.toolControls.fileAccess": {
          "type": "string",
          "default": "ask",
          "enum": [
            "allow",
            "ask",
            "deny"
          ],
          "description": "File access permission level: allow, ask, or deny"
        },
        "sweObeyMe.toolControls.terminalAccess": {
          "type": "string",
          "default": "ask",
          "enum": [
            "allow",
            "ask",
            "deny"
          ],
          "description": "Terminal access permission level: allow, ask, or deny"
        },
        "sweObeyMe.toolControls.networkAccess": {
          "type": "string",
          "default": "ask",
          "enum": [
            "allow",
