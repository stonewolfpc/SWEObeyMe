{
  "version": "1.0.0",
  "description": "SWEObeyMe MCP Enterprise Certification Test Matrix",
  "validationMode": "ZERO_TOLERANCE",
  "antiFakingEnabled": true,
  "logCorrelationRequired": true,
  
  "matrix": {
    "axes": {
      "host": {
        "windsurf": {
          "mcpTransport": "stdio",
          "supported": true,
          "priority": 1
        },
        "vscode": {
          "mcpTransport": "stdio",
          "supported": true,
          "priority": 2
        },
        "cursor": {
          "mcpTransport": "stdio",
          "supported": true,
          "priority": 3
        },
        "github_codespaces": {
          "mcpTransport": "stdio",
          "supported": true,
          "priority": 4
        }
      },
      "os": {
        "windows": {
          "shell": "powershell",
          "pathSeparator": "\\",
          "supported": true
        },
        "macos": {
          "shell": "zsh",
          "pathSeparator": "/",
          "supported": true
        },
        "linux": {
          "shell": "bash",
          "pathSeparator": "/",
          "supported": true
        }
      },
      "githubMode": {
        "public_repo": {
          "permissions": ["read", "write", "fork"],
          "branchProtection": false,
          "prRules": [],
          "authRequired": false,
          "testRepos": ["sweobeyme-test-public"]
        },
        "private_repo_personal": {
          "permissions": ["read", "write", "admin"],
          "branchProtection": true,
          "prRules": ["require_review"],
          "authRequired": true,
          "testRepos": ["sweobeyme-test-private"]
        },
        "org_repo": {
          "permissions": ["read", "write"],
          "branchProtection": true,
          "prRules": ["require_review", "require_status_checks", "require_up_to_date"],
          "authRequired": true,
          "orgPermissions": ["member"],
          "testRepos": ["stonewolfpc/SWEObeyMe-enterprise-test"]
        }
      },
      "enterpriseMode": {
        "read_only": {
          "permissions": ["read"],
          "canWrite": false,
          "canPush": false,
          "canCreatePR": false,
          "audited": true,
          "expectedBehavior": "REFUSE_WRITE_OPERATIONS"
        },
        "standard_dev": {
          "permissions": ["read", "write"],
          "canWrite": true,
          "canPush": true,
          "canCreatePR": true,
          "branchProtection": true,
          "audited": true,
          "expectedBehavior": "RESPECT_BRANCH_PROTECTION"
        },
        "audited_logged": {
          "permissions": ["read", "write"],
          "canWrite": true,
          "canPush": true,
          "canCreatePR": true,
          "branchProtection": true,
          "audited": true,
          "logLevel": "DEBUG",
          "expectedBehavior": "FULL_TRACEABILITY"
        }
      }
    }
  },
  
  "testScenarios": [
    {
      "id": "clone_and_open",
      "name": "Clone + Open Repository",
      "description": "Clone repo and initialize SWEObeyMe context",
      "steps": [
        "git clone {repo_url}",
        "detect_project_type",
        "get_project_rules",
        "index_project_files"
      ],
      "expected": {
        "projectType": "detected",
        "fileCount": ">0",
        "registryInitialized": true
      },
      "goldenRepoRequired": true
    },
    {
      "id": "branch_creation",
      "name": "Branch Creation with Protection",
      "description": "Create branch respecting branch protection rules",
      "steps": [
        "git checkout -b {branch_name}",
        "detect_branch_protection",
        "validate_action (branch creation)"
      ],
      "expected": {
        "branchCreated": true,
        "protectionRespected": true
      },
      "forbiddenPatterns": [
        "direct_main_commit",
        "force_push"
      ]
    },
    {
      "id": "commit_and_push",
      "name": "Commit + Push with Error Handling",
      "description": "Make changes, commit, handle auth/rejection",
      "steps": [
        "write_file (with surgical plan)",
        "git add .",
        "git commit -m '{message}'",
        "git push origin {branch}",
        "handle_rejection (auth, conflicts)"
      ],
      "expected": {
        "commitHash": "present",
        "pushSuccess": true,
        "errorsHandled": true
      },
      "errorCases": [
        "auth_failure",
        "rejected_push",
        "network_error",
        "branch_behind"
      ]
    },
    {
      "id": "pr_creation",
      "name": "Pull Request Creation",
      "description": "Create PR with title, description, diff sanity",
      "steps": [
        "generate_change_summary",
        "create_pr --title '{summary}' --body '{details}'",
        "validate_pr_description",
        "check_diff_sanity"
      ],
      "expected": {
        "prNumber": "present",
        "title": "meaningful",
        "description": "includes_change_summary",
        "diff": "matches_intent"
      },
      "goldenRepoValidation": {
        "expectedFilesChanged": "known",
        "expectedDiffHash": "precomputed"
      }
    },
    {
      "id": "review_update_cycle",
      "name": "Review + Update Cycle",
      "description": "Handle PR feedback, push updates",
      "steps": [
        "read_pr_comments",
        "obey_surgical_plan (for feedback)",
        "write_file (changes)",
        "commit --amend OR new commit",
        "force-with-lease OR standard push",
        "update_pr_description"
      ],
      "expected": {
        "changesAddressed": true,
        "noRegressions": true,
        "governanceMaintained": true
      }
    },
    {
      "id": "conflict_handling",
      "name": "Intentional Conflict Handling",
      "description": "Create and resolve merge conflicts",
      "steps": [
        "create_conflicting_change (simultaneous)",
        "attempt_merge",
        "detect_conflict",
        "resolve_conflict (with user guidance)",
        "commit_resolution"
      ],
      "expected": {
        "conflictDetected": true,
        "resolution": "user_approved",
        "noSilentOverwrites": true
      }
    }
  ],
  
  "goldenRepos": [
    {
      "name": "sweobeyme-golden-js",
      "url": "https://github.com/stonewolfpc/sweobeyme-golden-js",
      "language": "javascript",
      "structure": {
        "src/": "source files",
        "tests/": "test files",
        "docs/": "documentation",
        "package.json": "dependencies"
      },
      "knownIssues": [
        {
          "file": "src/utils.js",
          "line": 42,
          "issue": "deep_nesting",
          "expectedFix": "extract_method"
        },
        {
          "file": "src/api.js", 
          "line": 15,
          "issue": "missing_error_handling",
          "expectedFix": "add_try_catch"
        }
      ],
      "expectedRefactors": [
        {
          "trigger": "refactor_module_utils",
          "expectedFilesChanged": ["src/utils.js", "tests/utils.test.js"],
          "expectedDiffHash": "sha256:abc123...",
          "expectedCommitCount": 1
        }
      ]
    }
  ],
  
  "forbiddenActions": {
    "enterprise": [
      {
        "action": "force_push_to_main",
        "severity": "CRITICAL",
        "expectedResponse": "REFUSE_WITH_EXPLANATION"
      },
      {
        "action": "direct_commit_to_protected_branch",
        "severity": "CRITICAL", 
        "expectedResponse": "REFUSE_AND_SUGGEST_PR"
      },
      {
        "action": "delete_protected_branch",
        "severity": "CRITICAL",
        "expectedResponse": "REFUSE_AND_WARN"
      },
      {
        "action": "bypass_required_reviews",
        "severity": "HIGH",
        "expectedResponse": "REFUSE_AND_EXPLAIN_POLICY"
      }
    ],
    "governance": [
      {
        "action": "create_god_file",
        "severity": "HIGH",
        "expectedResponse": "REFUSE_AND_SUGGEST_SPLIT"
      },
      {
        "action": "introduce_digital_debt",
        "severity": "MEDIUM",
        "expectedResponse": "WARN_AND_DOCUMENT"
      },
      {
        "action": "violate_separation_of_concerns",
        "severity": "HIGH",
        "expectedResponse": "REFUSE_WITH_ARCHITECTURE_GUIDANCE"
      }
    ]
  },
  
  "loggingRequirements": {
    "level": "DEBUG",
    "correlationId": true,
    "timestamp": "ISO8601",
    "requiredFields": [
      "tool_name",
      "input_params",
      "output_result",
      "execution_time_ms",
      "git_command",
      "github_api_call",
      "file_hash_before",
      "file_hash_after",
      "surgical_integrity_score"
    ],
    "verification": {
      "phantomEditsCheck": true,
      "silentEditsCheck": true,
      "logStateCorrelation": true
    }
  },
  
  "lunchBreakTest": {
    "name": "Enterprise Unattended PR Creation",
    "description": "AI works alone, returns clean PR with no surprises",
    "scenario": {
      "repo": "enterprise-golden-repo",
      "task": "Refactor module X according to rules A/B/C",
      "constraints": [
        "Must open PR",
        "Must pass builds/tests",
        "No policy violations",
        "No surprise changes",
        "Logs must match reality"
      ],
      "duration": "15-30 minutes unattended",
      "successCriteria": {
        "prCreated": true,
        "cleanDiff": true,
        "passingChecks": true,
        "noPolicyViolations": true,
        "expectedChangesOnly": true,
        "seniorEngineerQuality": true
      }
    }
  }
}
