    "test:user-from-hell": "node tests/simulated-user-from-hell.js",
    "test:windsurf": "node tests/windsurf-runtime-behavior.js",
    "test:comprehensive": "node tests/run-all-tests.js",
    "test:full": "npm run build && npm run test:tools && npm run test:server && npm run test:mcp && npm run test:config && npm run test:comprehensive && npm run test:windsurf",
    "test:windsurf-package": "npm run package && npm run test:clean-env",
    "test:all": "node scripts/release-validation.js",
    "fuzz:windsurf": "node tests/fuzzer-windsurf-runtime.js",
    "fuzz:cursor": "node tests/fuzzer-generic-runtime.js",
    "fuzz:lmstudio": "node tests/fuzzer-generic-runtime.js",
