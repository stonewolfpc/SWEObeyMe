    "qa:e2e": "vitest run --config vitest.config.qa.js qa/e2e",
    "qa:static": "vitest run --config vitest.config.qa.js qa/static",
    "qa:property": "vitest run --config vitest.config.qa.js qa/property",
    "qa:coverage": "vitest run --config vitest.config.qa.js --coverage",
    "qa:full": "npm run qa:unit && npm run qa:integration && npm run qa:e2e && npm run qa:static && npm run qa:property"
