{
  "name": "swe-obey-me",
  "displayName": "SWEObeyMe - Surgical MCP Governor",
  "description": "The surgical MCP server that enforces architectural discipline on AI coding assistants. 700-line enforcement, auto-correction, sci-fi personality.",
  "version": "1.1.3",
  "type": "module",
  "publisher": "stonewolfpc",
  "icon": "icon.png",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "mcp",
    "ai",
    "code quality",
    "architecture",
    "surgical",
    "windsurf",
    "cascade"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "sweObeyMe.queryOracle",
        "title": "Query the Oracle",
        "category": "SWEObeyMe"
      },
      {
        "command": "sweObeyMe.openCSharpSettings",
        "title": "C# Bridge Settings",
        "category": "SWEObeyMe",
        "icon": "$(settings-gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sweObeyMe",
          "title": "SWEObeyMe",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "sweObeyMe": [
        {
          "type": "webview",
          "id": "sweObeyMe.csharpSettings",
          "name": "C# Bridge",
          "when": "config.sweObeyMe.enabled"
        }
      ]
    },
    "configuration": {
      "title": "SWEObeyMe",
      "properties": {
        "sweObeyMe.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable SWEObeyMe MCP Server"
        },
        "sweObeyMe.csharpBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable C# Bridge error detection"
        },
        "sweObeyMe.csharpBridge.keepAiInformed": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inform AI about C# errors in file reads"
        },
        "sweObeyMe.csharpBridge.severityThreshold": {
          "type": "number",
          "default": 0,
          "description": "Minimum severity level to report (0=Info, 1=Warning, 2=Error)"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish",
    "start": "node index.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.15.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "fs-extra": "^11.3.4",
    "jimp": "^1.6.0",
    "zod": "latest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stonewolfpc/SWEObeyMe"
  },
  "license": "MIT"
}
