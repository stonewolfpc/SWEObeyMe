# Explicitly include required directories
!dist/**
!lib/**
!utils/**
!docs/**
!examples/**
!scripts/**
!test-tools/**
!index.js
!extension.js
!quotes.js
!icon.png
!package.json
!package-lock.json
!README.md
!LICENSE
!.sweignore

# Exclude test files
tests/
__tests__/
*.test.js
*.spec.js
**/test/**
# Note: test-tools/ is included for schema validation tests
vscode/
test-electron/

# Exclude git
.git/
.gitignore
.github/

# Exclude development files
.vscode/
.idea/
ares-rig/
windsurf-rig/

# Exclude node_modules
node_modules/

# Exclude documentation files
ANTI_PATTERNS.md
BEST_PRACTICES.md
CODE_OF_CONDUCT.md
COMMON_PATTERNS.md
CONFIGURATION_EXAMPLES.md
CONTRIBUTING.md
DECISION_TREE.md
FAQ.md
PERFORMANCE_TIPS.md
QUICKSTART.md
SECURITY.md
TROUBLESHOOTING.md
docs/
*.md
!README.md

# Exclude build artifacts
build/
*.vsix
*.tgz

# Exclude temp and dump files
dump*.txt
*.tmp
*.log
*.bak
*.swp

# Exclude error logs (test artifacts)
error_log.json
error_patterns.json

# Exclude backup directories
project_registry/
backup/
backups/

# Exclude tool memory and corpus files
# Note: tool-memory.json is included as it's referenced by code
# Note: math_corpus and godot_corpus are included as they are referenced by code
scripts/tool-memory.json

# Exclude configuration files
.eslintrc.js
.prettierrc
.lintstagedrc.js
.czrc
.releaserc.json
.husky/

# Exclude workflows
.windsurf/

# Exclude schemas and project files
# Note: project_map.json is included as it's referenced by code
project_map.schema.json
