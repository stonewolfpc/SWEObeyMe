# Explicitly include required directories
!lib/**
!node_modules/**
!utils/**
!index.js
!extension.js
!quotes.js
!icon.png
!package.json
!package-lock.json
!.sweignore
!.sweobeyme-contract.md

# Exclude test files
tests/
__tests__/
*.test.js
*.spec.js
**/test/**
vscode/
test-electron/

# Exclude git
.git/
.gitignore
.github/

# Exclude documentation
README.md
LICENSE

# Exclude development files
.vscode/

# Exclude dump files
dump*.txt
