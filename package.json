{
  "name": "swe-obey-me",
  "displayName": "SWEObeyMe",
  "description": "SWEObeyMe - Anti vibe-coding surgical governance for AI-assisted development. 7 semantic tools with governance router enforcing 97+ internal handlers. v5.1.20",
  "version": "5.1.20",
  "type": "module",
  "publisher": "stonewolfpc",
  "icon": "icon.png",
  "main": "dist/extension.js",
  "bin": {
    "sweobeyme-doctor": "bin/sweobeyme-doctor.js"
  },
  "engines": {
    "vscode": "^1.61.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "mcp",
    "ai",
    "code quality",
    "architecture",
    "surgical",
    "windsurf",
    "cascade"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "mcpServers": [
      {
        "id": "sweobeyme",
        "command": "node",
        "args": [
          "--no-warnings",
          "./dist/mcp/server.js"
        ],
        "name": "SWEObeyMe",
        "description": "Surgical governance system for AI-assisted software engineering"
      }
    ],
    "commands": [
      {
        "command": "sweObeyMe.queryOracle",
        "title": "Query the Oracle",
        "category": "SWEObeyMe"
      },
      {
        "command": "sweObeyMe.showMenu",
        "title": "Show SWEObeyMe Menu",
        "category": "SWEObeyMe",
        "icon": "$(menu)"
      },
      {
        "command": "sweObeyMe.csharpSettings",
        "title": "Open C# Bridge Settings",
        "category": "SWEObeyMe",
        "icon": "$(settings-gear)"
      },
      {
        "command": "sweObeyMe.analyzeCSharp",
        "title": "Analyze Current C# File",
        "category": "SWEObeyMe",
        "icon": "$(search)"
      },
      {
        "command": "sweObeyMe.analyzeCpp",
        "title": "Analyze Current C++ File",
        "category": "SWEObeyMe",
        "icon": "$(search)"
      },
      {
        "command": "sweObeyMe.showDiagnostics",
        "title": "Show Diagnostics Panel",
        "category": "SWEObeyMe",
        "icon": "$(warning)"
      },
      {
        "command": "sweObeyMe.openCSharpSettings",
        "title": "SWEObeyMe Settings",
        "category": "SWEObeyMe",
        "icon": "$(settings-gear)"
      },
      {
        "command": "sweObeyMe.gitStatus",
        "title": "Show Git Status",
        "category": "SWEObeyMe",
        "icon": "$(git-branch)"
      },
      {
        "command": "sweObeyMe.gitBranch",
        "title": "Switch Git Branch",
        "category": "SWEObeyMe",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "sweObeyMe.checkpoint.create",
        "title": "Create Checkpoint",
        "category": "SWEObeyMe",
        "icon": "$(save)"
      },
      {
        "command": "sweObeyMe.checkpoint.list",
        "title": "List Checkpoints",
        "category": "SWEObeyMe",
        "icon": "$(list-tree)"
      },
      {
        "command": "sweObeyMe.checkpoint.revert",
        "title": "Revert to Checkpoint",
        "category": "SWEObeyMe",
        "icon": "$(discard)"
      },
      {
        "command": "sweObeyMe.checkpoint.delete",
        "title": "Delete Checkpoint",
        "category": "SWEObeyMe",
        "icon": "$(trash)"
      },
      {
        "command": "sweObeyMe.showOnboarding",
        "title": "Show Onboarding Guide",
        "category": "SWEObeyMe",
        "icon": "$(book)"
      },
      {
        "command": "sweObeyMe.patreonAudit",
        "title": "Patreon Audit",
        "category": "SWEObeyMe",
        "icon": "$(search)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sweObeyMe",
          "title": "SWEObeyMe",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "sweObeyMe": [
        {
          "id": "sweObeyMe.cockpit",
          "name": "Cockpit",
          "type": "webview",
          "icon": "$(shield)"
        }
      ]
    },
    "configuration": {
      "title": "SWEObeyMe",
      "properties": {
        "sweObeyMe.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable SWEObeyMe MCP Server",
          "order": 0
        },
        "sweObeyMe.errorReporting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Allow SWEObeyMe to send anonymous governance failure reports to its issue tracker. No personal data, file contents, or identity is ever included — only tool name, event type, and error message. Set to false to disable all automatic reporting.",
          "order": 1
        },
        "sweObeyMe.webhookUrl": {
          "type": "string",
          "default": "https://swe-obey-me-ivki.vercel.app/report",
          "description": "Webhook URL for automatic error reporting to GitHub (e.g., https://sweobeyme-webhook.vercel.app/report)",
          "order": 2
        },
        "sweObeyMe.backupPath": {
          "type": "string",
          "default": "",
          "description": "Custom backup directory path (leave empty for default)",
          "order": 2
        },
        "sweObeyMe.csharpBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable C# Bridge error detection",
          "order": 10
        },
        "sweObeyMe.csharpBridge.keepAiInformed": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inform AI about C# errors in file reads",
          "order": 11
        },
        "sweObeyMe.csharpBridge.severityThreshold": {
          "type": "number",
          "default": 0,
          "description": "Minimum severity level to report (0=Info, 1=Warning, 2=Error)",
          "order": 12
        },
        "sweObeyMe.csharpBridge.confidenceThreshold": {
          "type": "number",
          "default": 70,
          "description": "Minimum confidence percentage to show alerts (0-100)",
          "order": 13
        },
        "sweObeyMe.csharpBridge.deduplicateAlerts": {
          "type": "boolean",
          "default": true,
          "description": "Group identical warnings to reduce noise",
          "order": 14
        },
        "sweObeyMe.csharpBridge.alertCooldown": {
          "type": "number",
          "default": 30,
          "description": "Cooldown in seconds before repeating same alert",
          "order": 15
        },
        "sweObeyMe.csharpBridge.logVerbosity": {
          "type": "string",
          "default": "errors",
          "enum": [
            "silent",
            "errors",
            "verbose"
          ],
          "description": "Log verbosity level",
          "order": 16
        },
        "sweObeyMe.csharpBridge.detectors": {
          "type": "object",
          "default": {
            "missingUsing": true,
            "emptyCatch": true,
            "deepNesting": true,
            "asyncAwait": true,
            "resourceLeaks": true,
            "mathSafety": true,
            "nullReference": true,
            "staticMutation": true,
            "stringConcatenation": true
          },
          "description": "Enable/disable specific error detectors",
          "order": 17
        },
        "sweObeyMe.cppBridge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable C++ Bridge custom error detection (ADDS to Windsurf defaults, doesn't replace)",
          "order": 20
        },
        "sweObeyMe.cppBridge.severityThreshold": {
          "type": "number",
          "default": 0,
          "description": "Minimum severity level to report (0=Info, 1=Warning, 2=Error)",
          "order": 21
        },
        "sweObeyMe.cppBridge.confidenceThreshold": {
          "type": "number",
          "default": 70,
          "description": "Minimum confidence percentage to show alerts (0-100)",
          "order": 22
        },
        "sweObeyMe.cppBridge.deduplicateAlerts": {
          "type": "boolean",
          "default": true,
          "description": "Group identical warnings to reduce noise",
          "order": 23
        },
        "sweObeyMe.cppBridge.alertCooldown": {
          "type": "number",
          "default": 30,
          "description": "Cooldown in seconds before repeating same alert",
          "order": 24
        },
        "sweObeyMe.cppBridge.useClangTidy": {
          "type": "boolean",
          "default": false,
          "description": "Use clang-tidy for deeper analysis (requires clang-tidy installed)",
          "order": 25
        },
        "sweObeyMe.cppBridge.useCppcheck": {
          "type": "boolean",
          "default": false,
          "description": "Use cppcheck for static analysis (requires cppcheck installed)",
          "order": 26
        },
        "sweObeyMe.cppBridge.detectors": {
          "type": "object",
          "default": {
            "memory_leak_raw_new": true,
            "missing_virtual_destructor": true,
            "raw_array_new": true,
            "missing_null_check": true,
            "unused_include": true,
            "naked_delete": true,
            "exception_safety": true,
            "buffer_overflow_risk": true,
            "magic_number": true,
            "deep_nesting": true,
            "global_variable": true,
            "implicit_conversion": true
          },
          "description": "Enable/disable specific C++ error detectors",
          "order": 27
        },
        "sweObeyMe.initialization.scanOnNewProject": {
