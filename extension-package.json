{
  "name": "swe-obey-me",
  "displayName": "SWEObeyMe - Surgical MCP Governor",
  "description": "The surgical MCP server that enforces architectural discipline on AI coding assistants. 700-line enforcement, auto-correction, sci-fi personality.",
  "version": "1.0.9",
  "publisher": "stonewolfpc",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "mcp",
    "ai",
    "code quality",
    "architecture",
    "surgical",
    "windsurf",
    "cascade"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sweObeyMe.installMCP",
        "title": "Install SWEObeyMe MCP Server",
        "category": "SWEObeyMe"
      },
      {
        "command": "sweObeyMe.queryOracle",
        "title": "Query the Oracle",
        "category": "SWEObeyMe"
      }
    ],
    "configuration": {
      "title": "SWEObeyMe",
      "properties": {
        "sweObeyMe.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable SWEObeyMe MCP Server"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.15.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stonewolfpc/SWEObeyMe"
  },
  "license": "MIT"
}
