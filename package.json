  "scripts": {
    "vscode:uninstall": "node scripts/uninstall.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "compile": "npm run build",
    "start": "node index.js",
    "build": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=esm --platform=node && esbuild ./index.mjs --bundle --outfile=dist/mcp/server.js --external:vscode --format=esm --platform=node --external:velocityjs --external:dustjs-linkedin --external:atpl --external:liquor --external:twig --external:ejs --external:eco --external:jazz --external:jqtpl --external:hamljs --external:hamlet --external:whiskers --external:haml-coffee --external:hogan.js --external:templayed --external:walrus --external:mustache --external:just --external:ect --external:mote --external:toffee --external:dot --external:bracket-template --external:ractive --external:htmling --external:babel-core --external:plates --external:react-dom/server --external:react --external:vash --external:slm --external:marko --external:teacup/lib/express --external:coffee-script --external:squirrelly --external:twing && node -e \"const fs=require('fs'),p=require('path');const d='dist/mcp';fs.mkdirSync(d,{recursive:true});fs.copyFileSync('package.json',p.join(d,'package.json'));console.log('Copied package.json to '+p.join(d,'package.json'));\"",
    "watch": "esbuild ./extension.js --bundle --outfile=dist/extension.js --external:vscode --format=esm --platform=node --watch & esbuild ./index.mjs --bundle --outfile=dist/mcp/server.js --external:vscode --format=esm --platform=node --watch --external:velocityjs --external:dustjs-linkedin --external:atpl --external:liquor --external:twig --external:ejs --external:eco --external:jazz --external:jqtpl --external:hamljs --external:hamlet --external:whiskers --external:haml-coffee --external:hogan.js --external:templayed --external:walrus --external:mustache --external:just --external:ect --external:mote --external:toffee --external:dot --external:bracket-template --external:ractive --external:htmling --external:babel-core --external:plates --external:react-dom/server --external:react --external:vash --external:slm --external:marko --external:teacup/lib/express --external:coffee-script --external:squirrelly --external:twing && node -e \"const fs=require('fs'),p=require('path');const d='dist/mcp';fs.mkdirSync(d,{recursive:true});fs.copyFileSync('package.json',p.join(d,'package.json'));console.log('Copied package.json to '+p.join(d,'package.json'));\"",
    "build:public": "NODE_ENV=production BUILD_MODE=public node esbuild.config.js",
    "build:enterprise": "NODE_ENV=production BUILD_MODE=enterprise node esbuild.config.js",
    "build:dev": "BUILD_MODE=dev node esbuild.config.js",
    "build:watch": "BUILD_MODE=dev node esbuild.config.js --watch",
    "test": "npm run test:pre-release && npm run test:mcp-config-simulation && npm run test:mcp-config && npm run test:integration && npm run test:protocol && npm run test:schemas && npm run test:csharp && npm run test:unit && npm run test:property",
    "test:unit": "vitest run tests/unit",
    "test:integration:vitest": "vitest run tests/integration",
    "test:property": "vitest run tests/unit/session-state.property.test.js",
    "test:coverage": "vitest run --coverage",
    "test:coverage:check": "vitest run --coverage",
    "test:watch": "vitest",
    "test:pre-release": "node tests/test-pre-release-validation.js",
    "test:mcp-config-simulation": "node tests/test-mcp-config-simulation.js",
